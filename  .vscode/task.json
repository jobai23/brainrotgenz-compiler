{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cppbuild",
            "label": "build brainrot compiler",
            "command": "D:/disk c/mingw/mingw64/bin/gcc.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "-Wall",
                "-Wextra",
                "-pedantic",
                "src/main.c",
                "src/lexer.c",
                "src/parser.c",
                "src/evaluator.c",
                "-o",
                "${workspaceFolder}/brainrot.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": ["$gcc"],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}